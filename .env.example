# =============================================
# Variables de Entorno — Bot de Soporte Técnico
# =============================================
# Copie este archivo como "test.env" y complete con sus datos reales.
# NUNCA suba el archivo test.env al repositorio.

# Token del bot de Telegram (obtenido de @BotFather)
BOT_TOKEN=

# IDs de Telegram de los administradores (separados por coma)
ADMIN_IDS=123456789,987654321

# ID del grupo de Telegram donde se envían los tickets
ADMIN_GROUP_ID=-100XXXXXXXXXX

# Configuración de GLPI
GLPI_URL=http://your-glpi-server/glpi
GLPI_API_KEY=
